# Local config files with real credentials – never commit these
app/config/db.local.php
app/config/mail.local.php

# Composer dependencies – install on the server via composer install
vendor/
composer.lock

# Uploaded files
app/uploads/logos/*
app/uploads/photos/*
app/uploads/payments/*
app/uploads/documents/*

# Keep the upload directories but not their contents
!app/uploads/logos/.gitkeep
!app/uploads/photos/.gitkeep
!app/uploads/payments/.gitkeep
!app/uploads/documents/.gitkeep
